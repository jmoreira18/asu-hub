# Sin estas variables, la app cae en adapters de desarrollo (memoria + consola).
# Copiar a .env.local y completar para usar servicios reales.

# Supabase (storage — fuente de verdad). SERVICE_KEY es secreto de servidor.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Resend (email de confirmación).
RESEND_API_KEY=
RESEND_FROM=no-reply@tudominio.uy

# Google Sheets (acceso de emergencia, vía Web App de Apps Script).
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# Link público al documento de deslinde de responsabilidad (lo provee ASU).
NEXT_PUBLIC_WAIVER_URL=
