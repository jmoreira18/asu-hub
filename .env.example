# Sin estas variables, la app cae en adapters de desarrollo (memoria + consola).
# Copiar a .env.local y completar para usar servicios reales.

# Supabase (storage — fuente de verdad). SERVICE_KEY es secreto de servidor.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Resend (email de confirmación).
RESEND_API_KEY=
RESEND_FROM=no-reply@tudominio.uy

# Google Sheets (acceso de emergencia, vía Web App de Apps Script).
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# Link público al documento de deslinde de responsabilidad (lo provee ASU).
NEXT_PUBLIC_WAIVER_URL=

# Activa el paso de pago en la UI ("Pagar ahora" tras registrar). "true" = on.
# Off/ausente = Fase 1 sin pago. Decisión de producto de ASU (¿listo para cobrar?).
NEXT_PUBLIC_PAYMENT_ENABLED=

# Mercado Pago (pagos — Fase 2). Sin estas vars el pago cae en el adapter dev.
# ACCESS_TOKEN y WEBHOOK_SECRET son secretos de SERVIDOR: nunca al cliente,
# nunca con prefijo NEXT_PUBLIC_, nunca commiteados.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
# URL pública COMPLETA del webhook de pago. Obligatoria junto con ACCESS_TOKEN y
# WEBHOOK_SECRET: MP notifica a esta URL para confirmar el pago. Sin ella el
# grupo lanza (no se puede cobrar sin vía de confirmación). Dev = URL de ngrok,
# prod = dominio real. Ej: https://tu-dominio/api/payments/webhook
MP_NOTIFICATION_URL=
# URL pública COMPLETA de retorno tras pagar (back_urls + auto_return). MP
# redirige acá al pagador con ?status=&external_reference=<regId>. Obligatoria
# junto al resto del grupo MP. Solo UX de retorno; la confirmación es por webhook.
# Ej: https://tu-dominio/pago/retorno
MP_RETURN_URL=
# Id de un pago YA aprobado en sandbox, para el test `npm run test:mp`
# (verifyPayment). Lo produce el E2E del navegador. Solo testing. Ver
# docs/mp-sandbox-testing.md.
MP_TEST_PAYMENT_ID=

# Config de precios (JSON). Sin esto, se usa la config de desarrollo (DEV_PRICING).
# Estructura: { "currency": "UYU", "tiers": [{ "id", "from", "to", "prices": { "socio", "no-socio" } }] }
# Precios en CENTAVOS enteros; fechas ISO; rangos semiabiertos [from, to).
PRICING_CONFIG=
