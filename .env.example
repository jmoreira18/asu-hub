# Sin estas variables, la app cae en adapters de desarrollo (memoria + consola).
# Copiar a .env.local y completar para usar servicios reales.

# Supabase (storage — fuente de verdad). SERVICE_KEY es secreto de servidor.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Resend (email de confirmación).
RESEND_API_KEY=
RESEND_FROM=no-reply@tudominio.uy

# Google Sheets (acceso de emergencia, vía Web App de Apps Script).
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# Link público al documento de deslinde de responsabilidad (lo provee ASU).
NEXT_PUBLIC_WAIVER_URL=

# Mercado Pago (pagos — Fase 2). Sin estas vars el pago cae en el adapter dev.
# ACCESS_TOKEN y WEBHOOK_SECRET son secretos de SERVIDOR: nunca al cliente,
# nunca con prefijo NEXT_PUBLIC_, nunca commiteados.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Config de precios (JSON). Sin esto, se usa la config de desarrollo (DEV_PRICING).
# Estructura: { "currency": "UYU", "tiers": [{ "id", "from", "to", "prices": { "socio", "no-socio" } }] }
# Precios en CENTAVOS enteros; fechas ISO; rangos semiabiertos [from, to).
PRICING_CONFIG=
